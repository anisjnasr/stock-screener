# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# screener DB (never commit; use a volume or host storage in production)
data/*.db
data/*.db-shm
data/*.db-wal
data/*.sqlite
data/*.sqlite3
data/market-monitor-cache.json
data/breadth-cache.json
data/sectors-industries-cache.json
data/13f/
scripts/stock-type-counts.json

# artifacts & backups
.tmp-gh-artifacts/
data/backups/

# logs
/logs/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
