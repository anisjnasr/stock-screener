# Massive (formerly Polygon.io) — get your API key at https://polygon.io
# Copy this file to .env.local and add your key:
# cp .env.example .env.local
MASSIVE_API_KEY=your_massive_api_key_here

# Supabase — profile sync (cross-device watchlists, scans, settings)
# Create a free project at https://supabase.com, then run data/supabase-schema.sql
# in the SQL Editor and copy the URL + anon key from Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
